{
  "name": "lingwen-dashboard-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint:testid": "eslint tests/unit/**/*.spec.ts tests/fixtures/lint-testid/*.spec.ts --no-eslintrc -c .eslintrc.cjs --no-error-on-unmatched-pattern",
    "lint:testid-sync": "eslint --no-error-on-unmatched-pattern --no-eslintrc -c .eslintrc-testid-sync.cjs --rule '{\"testid-class-sync\": \"warn\"}' --rulesdir eslint-rules --ext .vue src/",
    "lint:vue": "eslint --no-error-on-unmatched-pattern --no-eslintrc -c .eslintrc-vue.cjs --ext .vue src/",
    "test:rule": "node --test eslint-rules/*.test.js tests/eslint-rules/*.test.cjs"
  },
  "dependencies": {
    "echarts": "^5.5.0",
    "mermaid": "^11.15.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/server-renderer": "^3.5.35",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^8.57.0",
    "eslint-plugin-local-rules": "^1.1.0",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^29.1.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^10.4.1"
  }
}
