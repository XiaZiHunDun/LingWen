#!/usr/bin/env sh
# Phase 8.40: Pre-commit hook — run lint-staged on staged files (scoped to changes)
# Phase 8.44.2: 改 lint-staged (Phase 8.40 跑 pnpm lint:all 全量太慢, 改 staged-only)
# Phase 9.58 F49: backend pytest smoke opt-in (LINGWEN_PRECOMMIT_PYTEST=1|last-failed)
#   subset: tests/ci/ + 1 dashboard integration (~2s); 0 阻塞默认 commit

# Frontend: explicit PATH setup (husky 4 shim broken)
export PATH="node_modules/.bin:$PATH"

# Frontend: staged-only lint via lint-staged
pnpm lint-staged

# Backend: opt-in pytest smoke (default off — full suite ~2min, CI 兜底)
case "${LINGWEN_PRECOMMIT_PYTEST:-}" in
  1|true|yes)
    cd "$(git rev-parse --show-toplevel)/novel-factory"
    pytest tests/ci/ \
      --ignore=tests/ci/test_precommit_pytest_smoke.py \
      tests/dashboard/test_api.py::TestHealthEndpoint \
      -q --timeout=30
    ;;
  last-failed)
    cd "$(git rev-parse --show-toplevel)/novel-factory"
    pytest --last-failed -q --timeout=30
    ;;
esac
