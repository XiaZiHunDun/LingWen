{
  "name": "lingwen-dashboard-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "e2e:smoke": "playwright test --project=smoke",
    "e2e:live": "LINGWEN_E2E_LIVE=1 playwright test --project=live-backend",
    "e2e:live-llm": "LINGWEN_E2E_LIVE=1 LINGWEN_E2E_LIVE_LLM=1 playwright test --project=live-llm",
    "e2e:a11y": "LINGWEN_E2E_LIVE=1 playwright test --project=a11y-l1",
    "e2e:visual-capture": "LINGWEN_E2E_LIVE=1 playwright test --project=visual-capture",
    "e2e:visual-regression": "LINGWEN_E2E_LIVE=1 playwright test --project=visual-regression",
    "e2e:visual-update": "LINGWEN_E2E_LIVE=1 playwright test --project=visual-regression --update-snapshots",
    "e2e:ui-metrics": "LINGWEN_E2E_LIVE=1 playwright test --project=ui-metrics",
    "e2e:quarantine": "LINGWEN_E2E_LIVE=1 PLAYWRIGHT_QUARANTINE=only playwright test --project=live-backend",
    "lint": "pnpm lint:all",
    "lint:testid": "eslint --config eslint.config.js tests/unit/**/*.spec.ts tests/fixtures/lint-testid/*.spec.ts --no-error-on-unmatched-pattern",
    "lint:testid-sync": "eslint --config eslint.config.js src/**/*.vue",
    "lint:vue": "eslint --config eslint.config.js src/**/*.vue",
    "lint:all": "pnpm lint:testid; pnpm lint:testid-sync && pnpm lint:vue",
    "lint:staged": "lint-staged",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.tests-relaxed.json --noEmit",
    "typecheck:tests:strict": "tsc -p tsconfig.json --noEmit",
    "typecheck:app": "vue-tsc -p tsconfig.app.json --noEmit",
    "test:rule": "node --test eslint-rules/*.test.js tests/eslint-rules/*.test.cjs",
    "prepare": "husky"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "mermaid": "^11.15.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/server-renderer": "^3.5.35",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.0.0",
    "eslint-plugin-local-rules": "^1.1.0",
    "eslint-plugin-vue": "^10.0.0",
    "husky": "9",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "2.2.8"
  },
  "pnpm": {
    "overrides": {
      "eslint-scope": "^9.0.0"
    }
  }
}
